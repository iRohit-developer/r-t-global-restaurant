{
  "info": {
    "name": "Restaurant System API",
    "_postman_id": "d946f58f-0eb9-42ad-b45b-c9d9f30c3192",
    "description": "Collection for auth, menu, and orders endpoints with role-based examples.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
